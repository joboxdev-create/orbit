# ORBIT — local environment template.
# Copy to `.env` and adjust. `.env` is gitignored and must never be committed.
#
# WHERE SECRETS SHOULD LIVE (recommendation):
# - Infra-level secrets (DB URL, a master encryption key) -> env / .env here.
# - Per-connector credentials (GitHub token, Jira key, ...) -> NOT in env.
#   They are entered per project in the app and stored ENCRYPTED in the DB,
#   decrypted at runtime with ORBIT_ENCRYPTION_KEY below. This keeps tenant
#   credentials out of the codebase and out of shared env files.

# --- Core (NestJS) ---
PORT=3001

# --- Web (Next.js) ---
# URL the web app uses (server-side) to reach the core API.
CORE_API_URL=http://localhost:3001/api

# --- Database (Postgres; used by docker-compose, wired into core later) ---
POSTGRES_USER=orbit
POSTGRES_PASSWORD=change-me-in-local
POSTGRES_DB=orbit
POSTGRES_PORT=5432
DATABASE_URL=postgresql://orbit:change-me-in-local@localhost:5432/orbit

# --- Secrets ---
# 32-byte key (base64) used to encrypt per-connector credentials at rest.
# Generate one with: openssl rand -base64 32
ORBIT_ENCRYPTION_KEY=
