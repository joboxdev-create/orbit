# ORBIT — local environment template.
# Copy to `.env` and adjust. `.env` is gitignored and must never be committed.
#
# WHERE SECRETS SHOULD LIVE (recommendation):
# - Infra-level secrets (DB URL, a master encryption key) -> env / .env here.
# - Per-connector credentials (GitHub token, Jira key, ...) -> NOT in env.
#   They are entered per project in the app and stored ENCRYPTED in the DB,
#   decrypted at runtime with ORBIT_ENCRYPTION_KEY below. This keeps tenant
#   credentials out of the codebase and out of shared env files.

# --- Core (NestJS) ---
PORT=3001

# --- Web (Next.js) ---
# URL the web app uses (server-side) to reach the core API.
CORE_API_URL=http://localhost:3001/api

# --- Database (Postgres; used by docker-compose, wired into core later) ---
POSTGRES_USER=orbit
POSTGRES_PASSWORD=change-me-in-local
POSTGRES_DB=orbit
POSTGRES_PORT=5432
DATABASE_URL=postgresql://orbit:change-me-in-local@localhost:5432/orbit

# --- Secrets ---
# 32-byte key (base64) used to encrypt per-connector credentials at rest.
# Generate one with: openssl rand -base64 32
ORBIT_ENCRYPTION_KEY=

# --- Auth (ORBIT internal) ---
# ORBIT owns its own identity (like Keycloak's admin or a DB superuser). Login
# is email/password, verified by the core; the core issues its own JWTs.
#
# Signing secret for access/refresh tokens. Generate: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
#
# Bootstrap admin, seeded by the core on startup (idempotent). This is the first
# account able to log in; other users are then created by an admin (no public
# signup). Analogous to KC_BOOTSTRAP_ADMIN_* / POSTGRES_USER.
ORBIT_ADMIN_EMAIL=admin@orbit.local
ORBIT_ADMIN_PASSWORD=change-me-in-local
#
# Web (Auth.js / NextAuth) — signs the session cookie. Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# --- Keycloak CONNECTOR (data plane, OPTIONAL) ---
# Keycloak is NOT used for ORBIT login — only as a connector. docker-compose can
# run a dev Keycloak to test the connector against. Console at http://localhost:${KEYCLOAK_PORT}.
KEYCLOAK_PORT=8080
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Connector credentials (orbit-admin service account) are entered per-instance in
# the app and stored ENCRYPTED; they are NOT read from env by the core.
# KEYCLOAK_ADMIN_CLIENT_ID=orbit-admin
# KEYCLOAK_ADMIN_CLIENT_SECRET=orbit-admin-dev-secret
