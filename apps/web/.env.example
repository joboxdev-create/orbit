# Web-specific env.
PORT=3000
# Server-side only (no NEXT_PUBLIC_ prefix -> not exposed to the browser).
CORE_API_URL=http://localhost:3001/api

# Auth.js (NextAuth) with a Credentials provider against the ORBIT core.
# AUTH_SECRET signs the session cookie (openssl rand -base64 32).
# AUTH_URL is the web's own base URL.
AUTH_SECRET=
AUTH_URL=http://localhost:3000
