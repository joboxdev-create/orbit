# Core-specific env (overrides root .env when running the core standalone).
PORT=3001
DATABASE_URL=postgresql://orbit:change-me-in-local@localhost:5432/orbit
ORBIT_ENCRYPTION_KEY=

# Auth (ORBIT internal). The core issues its own JWTs and hashes passwords.
# Generate JWT_SECRET with: openssl rand -base64 48
JWT_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Bootstrap admin, seeded on startup (idempotent). First account able to log in.
ORBIT_ADMIN_EMAIL=admin@orbit.local
ORBIT_ADMIN_PASSWORD=change-me-in-local
