{
  "name": "@orbit/desktop",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.sidecar.json && vite build",
    "build:sidecar": "tsc -p tsconfig.sidecar.json",
    "build:sidecar-bin": "node scripts/build-sidecar-bin.mjs",
    "build:mcp": "node scripts/build-mcp.mjs",
    "build:mcp-bin": "node scripts/build-mcp-bin.mjs",
    "sidecar": "node dist-sidecar/server.js",
    "tauri": "tauri",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.sidecar.json --noEmit && tsc -p tsconfig.mcp.json --noEmit",
    "clean": "rm -rf dist dist-sidecar dist-mcp .turbo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orbit/connector-sdk": "workspace:^",
    "@orbit/engine": "workspace:*",
    "@orbit/shared": "workspace:*",
    "@tauri-apps/api": "^2.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-icons": "^13.21.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.25.0",
    "postject": "^1.0.0-alpha.6",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
