{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Orbit",
  "version": "0.1.0",
  "identifier": "com.orbit.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm build:sidecar && pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm build:sidecar-bin"
  },
  "app": {
    "windows": [
      {
        "title": "Orbit",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/orbit-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
